<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#D3B93F"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView"
        android:layout_width="510dp"
        android:layout_height="235dp"
        android:layout_marginTop="60dp"
        android:background="#D70404"
        android:text="@string/write_the_number"
        android:textAppearance="@style/TextAppearance.AppCompat.Display3"
        android:textColor="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.51"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.123" />

    <EditText
        android:id="@+id/writeNumText"
        android:layout_width="265dp"
        android:layout_height="83dp"
        android:layout_marginStart="84dp"
        android:layout_marginTop="328dp"
        android:layout_marginEnd="42dp"
        android:layout_marginBottom="196dp"
        android:background="#D70404"
        android:ems="10"
        android:inputType="text"
        android:text=""
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        android:textColor="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/calculatButton"
        app:layout_constraintEnd_toStartOf="@+id/writeNumText2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <EditText
        android:id="@+id/writeNumText2"
        android:layout_width="292dp"
        android:layout_height="80dp"
        android:layout_marginEnd="160dp"
        android:layout_marginBottom="188dp"
        android:background="#D70404"
        android:ems="10"
        android:inputType="text"
        android:text=""
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        android:textColor="@color/white"
        app:layout_constraintBottom_toTopOf="@+id/calculatButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.37"
        app:layout_constraintStart_toEndOf="@+id/writeNumText" />

    <Button
        android:id="@+id/calculatButton"
        android:layout_width="285dp"
        android:layout_height="144dp"
        android:text="@string/calculation"
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        app:layout_constraintBottom_toTopOf="@+id/resultTextView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.51"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView"
        app:layout_constraintVertical_bias="0.904" />

    <TextView
        android:id="@+id/resultTextView"
        android:layout_width="394dp"
        android:layout_height="112dp"
        android:layout_marginBottom="172dp"
        android:background="#D70404"
        android:text=""
        android:textAppearance="@style/TextAppearance.AppCompat.Display1"
        android:textColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.52"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button" />

</androidx.constraintlayout.widget.ConstraintLayout>